# Set environment variables to opt in or out of KlaviyoForms and KlaviyoLocation pods
ENV['KLAVIYO_INCLUDE_FORMS'] = 'true'
ENV['KLAVIYO_INCLUDE_LOCATION'] = 'true'

# Force @react-native-firebase pods to build as static frameworks.
# The flag is a no-op in the default RN build
# (static libraries all around) but is required when use_frameworks! is enabled
# below (via USE_FRAMEWORKS env var), because RNFirebase's Swift/ObjC wrappers
# would otherwise default to dynamic linkage and fail to link against
# Firebase's static-only native pods (FirebaseCore, FirebaseMessaging, etc.).
# Kept set unconditionally so `USE_FRAMEWORKS=dynamic pod install` works without
# extra setup. Must be declared before any pod directives so the RNFirebase
# modules see it.
$RNFirebaseAsStaticFramework = true

def node_require(script)
   require Pod::Executable.execute_command('node', ['-p',
     "require.resolve(
       '#{script}',
       {paths: [process.argv[1]]},
     )", __dir__]).strip
 end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'KlaviyoReactNativeSdkExample' do
  config = use_native_modules!

  use_frameworks! :linkage => :static

  # Insert override klaviyo-swift-sdk pods below this line when needed
  pod 'KlaviyoCore', :git => 'https://github.com/klaviyo/klaviyo-swift-sdk.git', :branch => 'rel/5.3.0'
  pod 'KlaviyoSwift', :git => 'https://github.com/klaviyo/klaviyo-swift-sdk.git', :branch => 'rel/5.3.0'
  pod 'KlaviyoForms', :git => 'https://github.com/klaviyo/klaviyo-swift-sdk.git', :branch => 'rel/5.3.0'
  pod 'KlaviyoLocation', :git => 'https://github.com/klaviyo/klaviyo-swift-sdk.git', :branch => 'rel/5.3.0'

  # Setup permissions for react-native-permissions
  setup_permissions([
    'LocationWhenInUse',
    'LocationAlways',
  ])

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'KlaviyoReactNativeSdkExampleTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    # fmt 11.x uses C++20 consteval — ensure it's compiled with C++20
    installer.pods_project.targets.each do |target|
      if target.name == 'fmt'
        target.build_configurations.each do |build_config|
          build_config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        end
      end
    end
  end
end

target 'KlaviyoReactNativeSdkExampleExtension' do
  use_frameworks! :linkage => :static
  # Insert override klaviyo-swift-sdk extension pod below this line when needed
  pod 'KlaviyoSwiftExtension'
end

